{
  "manifest_version": 3,
  "name": "Hide Azure Subscription Details",
  "version": "1.0.0",
  "description": "Blurs Azure subscription IDs and subscription names on Azure portal pages.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://*.azure.com/*", "https://*.azure.net/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
